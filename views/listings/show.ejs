<% layout("/layouts/boilerplate") -%>
    <div class="row mt-3">
     <div class="col-8 offset-2">
    <h3 class="mb-4">Listing Details: </h3>
     </div>
     <div class="card col-6 offset-2">
        <img src="<%= listing.image.url %>" class="card-img-top show-img mb-2" alt="listing_image">
        <div class="card-body">
        <p class="card-text">
            <b><%= listing.title %></b><br>
            <%= listing.description %><br>
            &#8377;<%= listing.price != null 
            ? listing.price.toLocaleString("en-IN") 
            : "Price not available" %><br>
            <%= listing.location %><br>
            <%= listing.country %><br>
        </p>
        </div>
     </div>
    
    <br>
    <div class="btns mb-5 mt-3">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-2 edit-btn">Edit</a>
        <br><br>
        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-dark offset-4 dlt-btn">Delete</button>
        </form>
    </div>
    </div>

